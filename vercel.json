{
  "version": 2,
  "builds": [
    { "src": "proxy/server.js", "use": "@vercel/node" },
    { "src": "**/*.html",       "use": "@vercel/static" },
    { "src": "*.js",            "use": "@vercel/static" },
    { "src": "css/**",          "use": "@vercel/static" },
    { "src": "js/**",           "use": "@vercel/static" },
    { "src": "img/**",          "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/health",      "dest": "/proxy/server.js" },
    { "src": "/api/(.*)",    "dest": "/proxy/server.js" },
    { "handle": "filesystem" },
    { "src": "/(.*)",        "dest": "/index.html" }
  ]
}
