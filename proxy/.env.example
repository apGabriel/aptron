GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary
GEMINI_API_KEY=
PORT=3001
TIMEZONE=Europe/Madrid

# Supabase — used to validate the dashboard login JWT on every /api request.
# SUPABASE_URL is the project URL; SUPABASE_ANON_KEY is the publishable/anon key
# (same value the frontend uses). Without both, /api is locked (503).
SUPABASE_URL=
SUPABASE_ANON_KEY=

# ── Per-user Google Calendar linking (Step 2) ────────────────────────────────
# Enables /api/oauth/* + /api/calendar/*. If any of the three is blank the
# linking routes fail closed (503) and the legacy single-owner routes still work.
#   SERVICE_ROLE_KEY: the Supabase service_role key (secret! bypasses RLS to
#     read/write the calendar_connections vault). NEVER expose to the browser.
#   TOKEN_ENC_KEY: any long random string; encrypts stored refresh tokens at rest.
#     Generate e.g.  node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#   GOOGLE_REDIRECT_URI: an Authorized redirect URI on a "Web application" Google
#     OAuth client, pointing at this proxy's callback.
SUPABASE_SERVICE_ROLE_KEY=
TOKEN_ENC_KEY=
GOOGLE_REDIRECT_URI=http://localhost:3001/oauth/google/callback
