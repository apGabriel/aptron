# Supabase — used to validate the dashboard login JWT on every /api request.
# SUPABASE_URL is the project URL; SUPABASE_ANON_KEY is the publishable/anon key
# (same value the frontend uses). Without both, /api is locked (503).
SUPABASE_URL=
SUPABASE_ANON_KEY=
